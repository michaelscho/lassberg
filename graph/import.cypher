MERGE (l:Letter {id: 'lassberg-letter-1330'}) SET l.date = '1829-07-05', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '660', l.journal_number = '160', l.repository_place = 'Bern', l.repository_institution = 'Burgerbibliothek';
