MERGE (l:Letter {id: 'lassberg-letter-1476'}) SET l.date = '1830-08-06', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '740', l.journal_number = '260', l.repository_place = 'Marbach am Neckar', l.repository_institution = 'Schiller Nationalmuseum', l.published_in = 'Franz Pfeiffer (Hg.), Briefwechsel zwischen Joseph Freiherrn von Laßberg und Ludwig Uhland. Wien 1870, S. 174', l.published_in_url = 'https://www.digitale-sammlungen.de/en/view/bsb10620870?page=1';
MERGE (l:Letter {id: 'lassberg-letter-1477'}) SET l.date = '1830-08-08', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2321', l.repository_place = 'Krakau', l.repository_institution = 'Jagiellonische Bibliothek', l.published_in = 'Franz Pfeiffer, Zur Geschichte der deutschen Philologie. Briefe an Joseph Freiherrn von Laßberg. Postum hg. von Joseph Maria Wagner. In: Germania 13 (1868), S. 118-27, 244-49, 365-84 und 487-508, S. 373', l.published_in_url = 'https://upload.wikimedia.org/wikipedia/commons/a/a8/Germania_13_1868.pdf';
