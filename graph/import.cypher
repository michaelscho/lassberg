MERGE (l:Letter {id: 'lassberg-letter-1548'}) SET l.date = '1831-04-16', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '773', l.journal_number = '120', l.repository_place = 'Berlin', l.repository_institution = 'Staatsbibliothek Preussischer Kulturbesitz', l.published_in = 'Albert Leitzmann, Briefe des Freiherrn Joseph von Laßberg an Jakob Grimm. In: Sitzungsberichte der Preußischen Akademie der Wissenschaften. Berlin 1931, S. 1026-1105, S. 1077-80';
MERGE (l:Letter {id: 'lassberg-letter-1549'}) SET l.date = '1831-04-16', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2361', l.repository_place = 'Marbach am Neckar', l.repository_institution = 'Schiller Nationalmuseum', l.published_in = 'Franz Pfeiffer (Hg.), Briefwechsel zwischen Joseph Freiherrn von Laßberg und Ludwig Uhland. Wien 1870, S. 203', l.published_in_url = 'https://www.digitale-sammlungen.de/en/view/bsb10620870?page=1';
MERGE (l:Letter {id: 'lassberg-letter-1550'}) SET l.date = '1831-04-19', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '774', l.journal_number = '125', l.repository_place = 'St.Gallen', l.repository_institution = 'Kantonsbibliothek', l.signature = 'Vadianische Sammlung Ms 350 BA 223';
MERGE (l:Letter {id: 'lassberg-letter-1551'}) SET l.date = '1831-04-26', l.incipit = 'Mein hochverehrter Herr und Nachbar! Es sind hier keine Abdrücke der neuen Verfassung zum Verkauf angeboten worden; daher konnte ich Ihnen letzten Samstag auch kein Exemplar senden. Herr Oberamtmann h', l.text = 'Mein hochverehrter Herr und Nachbar! Es sind hier keine Abdrücke der neuen Verfassung zum Verkauf angeboten worden; daher konnte ich Ihnen letzten Samstag auch kein Exemplar senden. Herr Oberamtmann hat mir nun aus der Verlegenheit geholfen, indem er einige der unter die Beamten zu verteilenden Exemplare übrig behielt und mir somit eines zu Ihren Händen abtrat. Nehmen Sie dasselbe als eine kleine Entschädigung des Staats dafür an, dass derselbe Ihrem Stande jeden Anspruch auf ein Amt entzogen hat. Heute Vormittag waren von 468 Stimmfähigen unseres Kreises 315 bei der Abstimmung anwesend; 18 weigerten sich gegen die Annahme der Verfassung; 297 aber stimmten ihr zu. Ein Produkt eigener Art ist der Katalogus der St. Galler Verfassungsräte. Selbst mit Gefahr, dass sie denselben schon durch Herrn K. Rath Allispach kennen, sende ich Ihnen das merkwürdige Aktenstück, doch unter der Bedingung, dass Sie dasselbe nicht aus dem Lande senden, indem die Ausgabe vergriffen sein soll und ich sonst kein Exemplar besitze. Ich wünsche sehr, dass unser Verfassungsrat einen ähnlichen Zensor finde. Ein solcher Merkur ist wohl im Stande, faulende Stoffe wegzuschaffen. Am besten gefiel mir Hermann von Muolen! Doch sind noch andere Charaktere vielleicht treffender gezeichnet. Von den Römermünzen sollen auch Ihnen einige Dutzend zum Ankauf angeboten worden sein, und wirklich sollen Sie mehrere Stücke gekauft haben. Es war mir diese Nachricht ein Trost, als ich von anderer Seite hörte, der ganze Schatz sei bereits verkauft. Ich war gestern auf der Stelle, wo gefunden wurde. Viele Arbeiter waren noch beschäftigt, den Grund umzuwühlen und fanden zuweilen noch einige Stücke. Übrigens ist der Boden gelblicher Ton, der keine Spur von früherem Anbau zeigt; erst seit 10 Jahren ist jenes Stück Feld gerödet worden, und noch liegt es im Schatten des südlich neben demselben sich ausdehnenden Waldes, von dem vielleicht Waldkirch den Namen hat. Ankäufe habe ich seither keine mehr gemacht, da man das Stück nur zu 12 Pfennig verkaufen will, unser Hausierer aber schon 40 Kreuzer dafür fordert. Herr Henking hat mich durch meinen Bruder einladen lassen, doch recht bald mit Ihnen in Blumenegg einen Besuch zu machen. Da er mit Bauen beschäftigt ist, entfernt er sich selten vom Haus, sodass wir ziemliche Gewissheit hätten, ihn anzutreffen. Ich meinerseits bin aber morgen und Freitag mit Schulexamen und kommenden Montag mit dem Jugendfest beschäftigt, sodass ich diese Woche nicht einmal Eppishausen, geschweige denn Blumenegg sehen kann. Wollen Sie Montag Nachmittag unsere junge Welt vor dem oberen Tor tanzen und Wettkämpfe austragen sehen und mit uns und Herrn Oberamtmanns Familie ein Abendessen in der Remise genießen, so werden Sie uns herzlich willkommen sein. Mit Bedauern lässt Ihnen meine Frau sagen, dass Ihre Unterhosen von dem Strumpfwirker Bockstorf noch nicht fertiggestellt worden sind. Eines kranken, nun gestorbenen Kindes halber durfte derselbe seit einigen Wochen seinen Webstuhl nicht mehr schwirren lassen, und so blieb dann auch Ihre Bestellung hängen; dagegen will sich Meister Bockstorf verpflichten, die von Ihnen gewünschte Arbeit, von jetzt an gerechnet, in möglichst kurzer Frist zu liefern. Indem ich mich und die Meinen Ihrer freundschaftlichen Verbundenheit empfehle, bin ich Ihr ergebenster Diakon Pupikofer. Bischofzell, die Bruti, alias Clet. & Marc. 1831 (26. April).', l.file = 'data/letters/lassberg-letter-1551.xml', l.has_fulltext = true, l.status = 'raw', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2362', l.repository_place = 'Frauenfeld', l.repository_institution = 'Staatsarchiv Thurgau', l.signature = '9\'45, 1.1/75.1', l.published_in = 'Johannes Meyer, Briefwechsel zwischen J. von Laszberg und Johann Adam Pupikofer. In: Alemannia 16 (1888), S. 1-32 und 97-154, S. 129', l.published_in_url = 'https://books.google.de/books?id=XWY5AAAAMAAJ';
MERGE (l:Letter {id: 'lassberg-letter-1552'}) SET l.date = '1831-04-27', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2363', l.repository_place = 'Winterthur', l.repository_institution = 'Stadtbibliothek', l.signature = 'Ms BRH 513/91';
MERGE (l:Letter {id: 'lassberg-letter-1553'}) SET l.date = '1831-04-28', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '775', l.journal_number = '?';
MERGE (l:Letter {id: 'lassberg-letter-1554'}) SET l.date = '1831-05-05', l.incipit = 'Mein hochverehrter Herr und Nachbar! Damit Sie ja Herrn Uhland das Thanhuserlied nicht länger vorenthalten, sende ich Ihnen dasselbe nicht nur in originali, sondern auch von einer copia begleitet zurü', l.text = 'Mein hochverehrter Herr und Nachbar! Damit Sie ja Herrn Uhland das Thanhuserlied nicht länger vorenthalten, sende ich Ihnen dasselbe nicht nur in originali, sondern auch von einer copia begleitet zurück; denn es wäre doch nicht recht, wenn aus dem einzigen Grund, dass Ihr Herr Singmeister auch Ihr Fechtmeister war, jene merkwürdige Melodie nicht unter Ihre Notizen über den Minnegesang aufgenommen werden sollte. Wenn Sie wieder zu mir kommen, wird Ihnen meine Tochter den Thanhuser vorsingen, und Sie tun ihr dann wohl den Gefallen, ihr auch die übrigen Strophen mitzuteilen. Herr Pfarrer Vögeli wünscht zu wissen, von welcher Familie der Rudolfus thesaurarius ecclesiae Constant. gewesen sei, der 1300 ff. vorkömmt, auch Propst vom Zürich-Großmünster war, obwohl nie in Zürich residierend und XI. kal. Oct. 1309 starb? Können Sie darüber Auskunft geben, so werden Sie vielen Dank ernten; denn es scheint Herrn Pfarrer Vögeli viel daran gelegen zu sein. Ich lege Ihnen hier meinen Auszug aus den Schultheiß. Kollektaneen bei, damit Sie prüfen, ob er als Register genügt. Angenehm wäre es mir, auch den ersten oder dritten Band dieser Kollektaneen durchzugehen. Wir sind hocherfreut über den angenehm zugebrachten Tag letzten Mittwoch wieder nach Hause zurückgekommen. Ich will hoffen, dass die Feuchtigkeit des Waldes auch Ihnen keinen Schaden gebracht hat. Mit herzlicher Ergebenheit bin ich Ihr Diakon Pupikofer. Bischofzell, 5. Mai 1831.', l.file = 'data/letters/lassberg-letter-1554.xml', l.has_fulltext = true, l.status = 'raw', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2364', l.repository_place = 'Frauenfeld', l.repository_institution = 'Staatsarchiv Thurgau', l.signature = '9\'45, 1.1/75.1', l.published_in = 'Johannes Meyer, Briefwechsel zwischen J. von Laszberg und Johann Adam Pupikofer. In: Alemannia 16 (1888), S. 1-32 und 97-154, S. 130', l.published_in_url = 'https://books.google.de/books?id=XWY5AAAAMAAJ';
