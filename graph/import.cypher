MERGE (l:Letter {id: 'lassberg-letter-2197'}) SET l.date = '1840-08-04', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '1102', l.journal_number = '162', l.repository_place = 'Donaueschingen', l.repository_institution = 'Fürstlich Fürstenbergisches Archiv';
MERGE (l:Letter {id: 'lassberg-letter-2198'}) SET l.date = '1840-08-05', l.incipit = 'Auf der alten Meersburg am 5. August 1840. Ihre allseitige glückliche Heimkunft nach der cella episcopalis haben wir aus Ihrem Schreiben, mein verehrter Freund, mit Vergnügen ersehen. Es ist doch, als', l.text = 'Auf der alten Meersburg am 5. August 1840. Ihre allseitige glückliche Heimkunft nach der cella episcopalis haben wir aus Ihrem Schreiben, mein verehrter Freund, mit Vergnügen ersehen. Es ist doch, als ob Sie den Jupiter Pluvius mit sich fortgenommen hätten; denn seitdem haben wir täglichen Sonnenschein. Wie freut es mich, dass Sie mir Gelegenheit geben wollen, Ihnen etwas Angenehmes zu erweisen, indem Sie mir erlauben, Ihnen den einzelnen Band der Lesungen des Canisius zu übermachen, welcher den Monachus San Gallensis de gestis Caroli M. enthält. Behalten Sie ihn als ein Andenken Ihres sehr alten Freundes auf der viel älteren Meersburg, und seien Sie versichert, dass ich, bei vorkommenden Fällen, nicht ermangeln werde, auf Ihre Wünsche in Bezug auf die übrigen in Ihrem Schreiben genannten Bücher, Rücksicht zu nehmen. Wir haben nun unsere westphälische Reise auf den nächsten Frühling vertagt, da unsere Heimreise schon in die Zeit fiel, wo die Tage kurz und die Nächte lang zu werden anfangen, folglich die Dauer der Heimreise sich auf eine unangenehme Weise verlängert hätte. Wir hoffen nun, dass meine Schwiegermutter und Schwägerin diesen Herbst zu uns kommen, den Winter über bleiben und im Frühling uns mit nach dem Pumpernikelland nehmen werden. Sie können, lieber Freund, uns also diesen Herbst wohl noch besuchen und dabei versuchen, ob die schwäbischen oder die schweizerischen Trauben süßer sind? Vorgestern und gestern hatten wir Herrn Prof. De Wette und Frau aus Basel zum Besuch; sie kamen aus Graubünden und gingen gestern noch nach Berlingen, wo sie bei dem dortigen Pfarrer ein paar Tage verbringen wollen. Ich aber bin wieder am Auspacken meiner Bücherkisten geraten und hoffe, endlich in ein paar Wochen damit fertig zu werden. Dann kommt das Ordnen, was aber wahrscheinlich bei Eintritt des Winters wieder unterbrochen wird; indessen muss man immer etwas tun. Grüßen Sie von uns freundlichst Ihre Reisegefährten, und auch den, welchen wir so gerne unter Ihnen gesehen hätten, unseren guten und lieben Imhoff. Und nun Gott befohlen! von Ihrem alten hinkenden Freund J. von Laßberg', l.file = 'data/letters/lassberg-letter-2198.xml', l.has_fulltext = true, l.status = 'raw', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '1103', l.journal_number = '164', l.repository_place = 'Winterthur', l.repository_institution = 'Stadtbibliothek', l.signature = 'Ms BRH 46/5', l.published_in = 'Johannes Meyer, Briefwechsel zwischen J. von Laszberg und Johann Adam Pupikofer. In: Alemannia 15 (1887), S. 231-88, S. 281', l.published_in_url = 'https://books.google.de/books?id=dXkKAAAAIAAJ';
MERGE (l:Letter {id: 'lassberg-letter-2199'}) SET l.date = '1840-08-05', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '1104', l.journal_number = '165', l.repository_place = 'Erpernburg', l.repository_institution = 'Archiv der Freiherren von und zu Brenken', l.published_in = 'Volker Schupp, Unbekannte Briefe des Reichsfreiherrn Joseph von Laßberg an Friedrich Carl Freiherrn von und zu Brenken. In: WZ 128(1978), S. 119-59. Ebenso in: Badische Heimat 58 (1978), S. 397-427, S. 153', l.published_in_url = 'https://www.lwl.org/westfaelische-geschichte/txt/wz-9494.pdf';
MERGE (l:Letter {id: 'lassberg-letter-2200'}) SET l.date = '1840-08-05', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2690', l.repository_place = 'Freiburg i.Br.', l.repository_institution = 'Universitätsbibliothek', l.signature = 'Autograph Nr. 1703', l.facsimile_url = 'https://dl.ub.uni-freiburg.de/diglit/autogr1703/', l.published_in = 'Franz Pfeiffer, Zur Geschichte der deutschen Philologie. Briefe an Joseph Freiherrn von Laßberg. Postum hg. von Joseph Maria Wagner. In: Germania 13 (1868), S. 118-27, 244-49, 365-84 und 487-508, S. 501', l.published_in_url = 'https://upload.wikimedia.org/wikipedia/commons/a/a8/Germania_13_1868.pdf';
