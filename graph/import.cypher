MERGE (l:Letter {id: 'lassberg-letter-2138'}) SET l.date = '1839-09-10', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '1063', l.journal_number = '142', l.repository_place = 'Tübingen', l.repository_institution = 'Universitätsbibliothek';
MERGE (l:Letter {id: 'lassberg-letter-2139'}) SET l.date = '1839-09-12', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2668', l.repository_place = 'Frauenfeld', l.repository_institution = 'Staatsarchiv Thurgau', l.signature = '9\'45, 1.1/75.1', l.published_in = 'Johannes Meyer, Briefwechsel zwischen J. von Laszberg und Johann Adam Pupikofer. In: Alemannia 16 (1888), S. 1-32 und 97-154, S. 145', l.published_in_url = 'https://books.google.de/books?id=XWY5AAAAMAAJ';
MERGE (l:Letter {id: 'lassberg-letter-2140'}) SET l.date = '1839-09-17', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '1064', l.journal_number = '145', l.repository_place = 'Karlsruhe', l.repository_institution = 'Badische Landesbibliothek';
MERGE (l:Letter {id: 'lassberg-letter-2141'}) SET l.date = '1839-09-26', l.incipit = 'Bischofzell, 26. September 1839. Mein hochverehrtester Herr Baron! Soeben von Frauenfeld zurückgekehrt, vernehme ich, dass Herr von Muralt Ihnen die 10 Fässer Kalk über Konstanz übermacht und Ihnen zu', l.text = 'Bischofzell, 26. September 1839. Mein hochverehrtester Herr Baron! Soeben von Frauenfeld zurückgekehrt, vernehme ich, dass Herr von Muralt Ihnen die 10 Fässer Kalk über Konstanz übermacht und Ihnen zugleich zu dem Dienste sich bereit erklärt habe, Ihnen einen mit der Verfertigung der Kalkgüsse vertrauten Mann zu senden; es liege ihm nämlich daran, dass die Arbeit gelinge, und so wäre es ihm selbst lieb, dieselbe durch technische Kunstfertigkeit gesichert zu wissen. Sie mögen also gefälligst disponieren, und Ihre Befehle entweder mittelbar durch mich oder unmittelbar an Herrn von Muralt erteilen. Zu näherer Aufklärung über die Spedition des Kalkes muss ich indessen nachtragen, dass ich zwar mit den Utwyler Fuhrleuten unterhandelte, aber von einem Tage zum anderen aufgezögert wurde, und daher zuletzt nichts Besseres zu tun wusste, als Herrn v. M. selbst die Spedition zu übertragen, in der Meinung, dass, wenn Sie vielleicht auch 15 xr mehr Gebühr für das Fass zahlen, dies weniger wichtig sei als eine Verzögerung bis zum Frühjahr. Auch glaubt Herr v. M., da der Kalkguss überdeckt werde mit Erde, so sei keine Bedenklichkeit, denselben diesen Herbst noch zu fertigen. Etwas anderes wäre, wenn er der freien Luft über den Winter ausgesetzt wäre. Dies wissen Sie freilich schon längst; allein als gewissenhafter Diener berichte ich alles, was zur Sache gehört. General Imhof ist seit 10 Tagen in Hauptwyl, und unser lieber Imhof hat seine letzte Willenserklärung nach seinem Beirat unterzeichnen lassen. Es war mir bei dem Akt ganz wehmütig; aber Imhof selbst blieb so ruhig, wie er immer ist, im Gegenteil, er schien freudig in dem Bewusstsein, einmal mit der Welt abgeschlossen zu haben. Das wird ihn aber nicht hindern, seinen Bruder über den See zu Ihnen zu begleiten. Noch weiß ich indessen den Tag nicht. Da wir aber auf morgen Abend zu einem Abendessen mit Herrn Scherbs nach Hauptwyl eingeladen sind, so schließe ich daraus, dass die Abreise nahe sei, und dass Sie der Ankunft der lieben Gäste im Anfange der künftigen Woche entgegensehen dürfen. Ich würde sie gerne begleiten; aber Amtsgeschäfte machen Dienstag bis Freitag meine Anwesenheit hier unerlässlich, und ob ich bei Gelegenheit des Seminar Examens in Kreuzlingen am 14. oder 21. Oktober und den darauf folgenden Tagen zu Ihnen hinüberschwimmen könnte, ist sehr zweifelhaft. Gebundene schwimmen schlecht, selbst wenn sie die Hexerei verstehen. Soll ich Ihnen noch etwas von der Politik schreiben und von der Regierungsliederlichkeit und dem heiligen Eifer des Unverstandes der Volkssouveränität? O nein! Taciti deploremus vanitatem. Gott befohlen seien Sie mit Ihrer Frau Gemahlin und Ihren lieblichen Kindern; das Ungesehene mit eingeschlossen! Mit der innigsten Verehrung bleiben Ihre Bischofzellischen Freunde Ihnen zugetan, besonders Ihr Pupikofer.', l.file = 'data/letters/lassberg-letter-2141.xml', l.has_fulltext = true, l.status = 'raw', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2669', l.repository_place = 'Frauenfeld', l.repository_institution = 'Staatsarchiv Thurgau', l.signature = '9\'45, 1.1/75.1', l.published_in = 'Johannes Meyer, Briefwechsel zwischen J. von Laszberg und Johann Adam Pupikofer. In: Alemannia 16 (1888), S. 1-32 und 97-154, S. 145', l.published_in_url = 'https://books.google.de/books?id=XWY5AAAAMAAJ';
