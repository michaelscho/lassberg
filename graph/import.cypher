MERGE (l:Letter {id: 'lassberg-letter-1826'}) SET l.date = '1836-01-01', l.incipit = 'Seiner Wohlwürden Herrn Diacon Pupikofer zu Bischofszell. Eppishausen am 1. Januar 1836. Prosit Neujahr! Da bekanntlich das castrum doloris, sonst auch Ofen genannt, in dem hinteren und respektiven ob', l.text = 'Seiner Wohlwürden Herrn Diacon Pupikofer zu Bischofszell. Eppishausen am 1. Januar 1836. Prosit Neujahr! Da bekanntlich das castrum doloris, sonst auch Ofen genannt, in dem hinteren und respektiven oberen Speisezimmer, lange zuvor geheizt werden muss, ehe es eine warme Stube macht; so geschieht an dieser Stelle im Namen des frommen und löblichen Gynäcáums zu Eppishausen die geziemende Anfrage: ob unsere lieben Nachbarn, die Episcopicellenses, morgen kommen werden, das Fest des heiligen Berthold in unserem armen Klösterlein mit uns zu feiern? In Erwartung einer erfreulichen Antwort, hat meine Frau bereits ein halb Klafter Holz in den Fornax werfen lassen, auf dass Sadrach, Mysach und Abdenago morgen lobsingend darin herumspazieren können. In fröhlicher Erwartung die beiden Häuser Scherb & Pupikofer morgen persönlich grüßen zu dürfen. Semper idem Laßbergius.', l.file = 'data/letters/lassberg-letter-1826.xml', l.has_fulltext = true, l.status = 'raw', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '888', l.journal_number = '1', l.repository_place = 'Winterthur', l.repository_institution = 'Stadtbibliothek', l.signature = 'Ms BRH 46/5', l.published_in = 'Johannes Meyer, Briefwechsel zwischen J. von Laszberg und Johann Adam Pupikofer. In: Alemannia 15 (1887), S. 231-88, S. 273', l.published_in_url = 'https://books.google.de/books?id=dXkKAAAAIAAJ';
MERGE (l:Letter {id: 'lassberg-letter-1827'}) SET l.date = '1836-02-10', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '889', l.journal_number = '29', l.repository_place = 'Karlsruhe', l.repository_institution = 'Badische Landesbibliothek';
