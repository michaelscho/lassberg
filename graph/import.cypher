MERGE (l:Letter {id: 'lassberg-letter-1643'}) SET l.date = '1832-03-26', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2412', l.repository_place = 'Krakau', l.repository_institution = 'Jagiellonische Bibliothek', l.published_in = 'Franz Pfeiffer, Zur Geschichte der deutschen Philologie. Briefe an Joseph Freiherrn von Laßberg. Postum hg. von Joseph Maria Wagner. In: Germania 13 (1868), S. 118-27, 244-49, 365-84 und 487-508, S. 376', l.published_in_url = 'https://upload.wikimedia.org/wikipedia/commons/a/a8/Germania_13_1868.pdf';
