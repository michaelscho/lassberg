MERGE (l:Letter {id: 'lassberg-letter-1312'}) SET l.date = '1829-05-05', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '647', l.journal_number = '98', l.repository_place = 'Bern', l.repository_institution = 'Burgerbibliothek';
MERGE (l:Letter {id: 'lassberg-letter-1313'}) SET l.date = '1829-05-14', l.incipit = 'Mein verehrtester Herr und Gönner! Mein Korrespondent in St. Gallen verlangt Bluntschlis und Werdmüllers Memorabilia wieder zurück, weil er die selben zur Anfertigung eines neuen Katalogs in die Bibli', l.text = 'Mein verehrtester Herr und Gönner! Mein Korrespondent in St. Gallen verlangt Bluntschlis und Werdmüllers Memorabilia wieder zurück, weil er die selben zur Anfertigung eines neuen Katalogs in die Bibliothek zurückgeben müsse. Ich muss Sie also bitten, mir den Band, den Sie haben, zuzusenden. Da ich das ganze Werk noch nicht benutzt habe, so lasse ich mir dasselbe später wiedergeben, und so steht es auch wieder zu Ihren Diensten. Die Minnesänger habe ich durchblättert und somit meine dringendste Neugier, besonders rücksichtlich der Thurgauer Sänger, befriedigt. Da die nächsten Tage mich amtlich beschäftigen, so will ich Ihnen die Sammlung nicht länger vorenthalten. Mein lieber Schwager dankt Ihnen gar sehr für den angenehmen Tag, den Sie ihm gewährt haben. Ich hatte den doppelten Genuss, bei Ihnen und bei meinem Schwager zugleich zu sein, und selbst ein Gast, noch die Pflicht der Gastfreundschaft zu erfüllen. Leben Sie wohl und suchen Sie in des Bischofs Celle bald heim Ihren Pupikofer. den 14. Mai 1829. N. S. Am leichtesten könnten Sie das Buch morgen, d. h. Freitag Nachmittags durch den Herrn Alispach hierher gehen lassen.', l.file = 'data/letters/lassberg-letter-1313.xml', l.has_fulltext = true, l.status = 'raw', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2247', l.repository_place = 'Frauenfeld', l.repository_institution = 'Staatsarchiv Thurgau', l.signature = '9\'45, 1.1/75.1', l.published_in = 'Johannes Meyer, Briefwechsel zwischen J. von Laszberg und Johann Adam Pupikofer. In: Alemannia 16 (1888), S. 1-32 und 97-154, S. 31', l.published_in_url = 'https://books.google.de/books?id=XWY5AAAAMAAJ';
MERGE (l:Letter {id: 'lassberg-letter-1314'}) SET l.date = '1829-05-16', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '648', l.journal_number = '107', l.repository_place = 'Krakau', l.repository_institution = 'Jagiellonische Bibliothek', l.published_in = 'Martin Harris, Joseph von Laßberg im Briefwechsel mit norddeutschen Germanisten. Neu aufgefundene Briefe zur Geschichte der germanischen Philologie. In: Euphorion 80 (1986), S. 46-82, S. 71.';
