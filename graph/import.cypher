MERGE (l:Letter {id: 'lassberg-letter-1433'}) SET l.date = '1830-04-04', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '714', l.journal_number = '134', l.repository_place = 'Donaueschingen', l.repository_institution = 'Fürstlich Fürstenbergisches Archiv';
MERGE (l:Letter {id: 'lassberg-letter-1434'}) SET l.date = '1830-04-07', l.incipit = 'E. am 7. April 1830. Ich bin gestern glücklich zwischen zwei Regen durchlaufend in der Villa Eponis angekommen; habe aber unterwegs viel Beschwerde von dem durch den Jupiter Pluvius sehr schlüpfrig ge', l.text = 'E. am 7. April 1830. Ich bin gestern glücklich zwischen zwei Regen durchlaufend in der Villa Eponis angekommen; habe aber unterwegs viel Beschwerde von dem durch den Jupiter Pluvius sehr schlüpfrig gemachten Boden auszustehen gehabt; so dass ich verwundert bin, nie die Erde geküsst zu haben: hingegen muss ich gestehen sehr ermüdet meine Stube wieder betreten zu haben: nichtsdestotrotz wurde noch bis 12 Uhr im Codex Traditionum Galliae gelesen, er ist mir wieder ganz neu vorgekommen, und ich verspreche mir eine große Ernte darin zu machen. Nun jedoch, womit ich freilich hätte anfangen sollen, empfangen Sie meinen besten Dank für die gastfreie Aufnahme und Behandlung, welche Sie dem alten Meister Sepp haben angedeihen lassen; kommen Sie jetzt nur bald, mit Weib und Kindern in die Waldklause, damit ich es wettmachen kann. Wenn Sie mir hätten sagen wollen, was das Bier kostet; so hätte ich Ihnen heute mit dem Karren auch das Geld senden können; lassen Sie miches also wissen, damit ich nicht zu lange in Ihrer Schuld bleibe. Bei meiner Rückkehr nach Hause fand ich einen interessanten Brief von dem lustigen Ritter von Lang aus Ansbach, welcher mir sein Buch von den bayerischen Gaue sendet, und worin auch einiges von Rätien und Thurgau vorkommt. Auch eine Abhandlung über die in Bayern verehrten Heiligen und eine dito gegen die Monumenta Boica, von denen er behauptet, dass auch nicht eine einzige Urkunde richtig abgedruckt sei. Ich komme morgen nicht zu Ihnen; sondern werde in der Marcha Sumbrina meine Andacht halten. Empfehlen Sie mich aufs Beste den Ihren, und in dem Hause des Herrn Oberamtmanns Scherb. Da es sonst nichts Neues gibt; so bleibt alles beim Alten, so auch Ihr ergebenster J. v. Laßberg. Seiner Hocherwürden dem Herrn Pfarrer Pupikofer zu Bischofszelle', l.file = 'data/letters/lassberg-letter-1434.xml', l.has_fulltext = true, l.status = 'raw', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '715', l.journal_number = '120', l.repository_place = 'Winterthur', l.repository_institution = 'Stadtbibliothek', l.signature = 'Ms BRH 46/5', l.published_in = 'Johannes Meyer, Briefwechsel zwischen J. von Laszberg und Johann Adam Pupikofer. In: Alemannia 15 (1887), S. 231-88, S. 256', l.published_in_url = 'https://books.google.de/books?id=dXkKAAAAIAAJ';
MERGE (l:Letter {id: 'lassberg-letter-1435'}) SET l.date = '1830-04-09', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '716', l.journal_number = '123', l.repository_place = 'Berlin', l.repository_institution = 'Staatsbibliothek Preussischer Kulturbesitz', l.published_in = 'Albert Leitzmann, Briefe des Freiherrn Joseph von Laßberg an Jakob Grimm. In: Sitzungsberichte der Preußischen Akademie der Wissenschaften. Berlin 1931, S. 1026-1105, S. 1068-71';
