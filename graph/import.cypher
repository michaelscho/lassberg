MERGE (l:Letter {id: 'lassberg-letter-1460'}) SET l.date = '1830-06-26', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2313', l.repository_place = 'Bern', l.repository_institution = 'Burgerbibliothek';
