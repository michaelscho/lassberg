MERGE (l:Letter {id: 'lassberg-letter-1794'}) SET l.date = '1834-10-18', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '874', l.repository_place = 'Bruchhausen', l.repository_institution = 'Archiv der Freiherren von Fürstenberg';
MERGE (l:Letter {id: 'lassberg-letter-1795'}) SET l.date = '1834-11-12', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2507', l.repository_place = 'Stapel bei Havixbeck', l.repository_institution = 'Archiv des Freiherrn Raitz von Frentz-Droste zu Hülshoff';
MERGE (l:Letter {id: 'lassberg-letter-1796'}) SET l.date = '1834-11-25', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2508', l.repository_place = 'Stapel bei Havixbeck', l.repository_institution = 'Archiv des Freiherrn Raitz von Frentz-Droste zu Hülshoff';
MERGE (l:Letter {id: 'lassberg-letter-1797'}) SET l.date = '1834-12-20', l.incipit = 'Hochwohlgeborener, Hochverehrtester Herr und Nachbar! Sie und Ihre Frau Gemahlin im Laufe dieser Woche, nach Ihrer endlich erfolgten, so lange ersehnten Heimkunft, mit dem Ausdruck meiner herzlichen F', l.text = 'Hochwohlgeborener, Hochverehrtester Herr und Nachbar! Sie und Ihre Frau Gemahlin im Laufe dieser Woche, nach Ihrer endlich erfolgten, so lange ersehnten Heimkunft, mit dem Ausdruck meiner herzlichen Freude zu begrüßen und Sie um Fortsetzung Ihres mir seit einer langen Reihe von Jahren erwiesenen Wohlwollens zu bitten, war am Anfang dieser Woche mein fester Entschluss. Ich wollte auf dem Heimweg von Kreuzlingen am Dienstag Abend oder Mittwoch bei Ihnen vorbeischauen, um mit eigenen Augen zu sehen, wie glücklich Sie in Ihrem neuen Verhältnis sind. Doch die feuchten Nebel, die mich belästigten, zwangen mich dazu, möglichst schnell zurückzukehren und auf meine Gesundheit für das baldige Weihnachtsfest zu achten - und so leider einen so lieben Wunsch, Sie diese Woche noch zu sehen, wenn auch widerwillig, aufzugeben. Damit mein Fernbleiben nicht als Zeichen von fehlendem Interesse erscheint, wollte ich dennoch diese Woche nicht verstreichen lassen, ohne Ihnen einen Beweis zu geben, dass ich oft an Eppishausen denke, und dass ich, wenn ich Fausts Künste beherrschen würde, über den Berg und durch den Wald zu Ihnen geschwebt wäre. Ihre Theorie ist zur Praxis geworden, die Minnesängerei zur Minnefängerei. Wir haben uns oft mit alten Rechtsbestimmungen beschäftigt. Vielleicht gibt Ihnen das beiliegende Kopialbuch die Möglichkeit, auch hier Theorie und Praxis zu vereinen und alte Herrschaftsrechte oder Besitzungen, die einst mit Eppishausen verbunden waren, wiederzuerlangen. Falls das nicht möglich oder gewollt ist, so machen Sie mir bitte die Freude, Ihnen zumindest die Rechtstitel zuzusenden und somit von meiner Seite aus getan zu haben, was ich konnte; sie können in jedem Fall zur Ergänzung Ihres Eppishausenschen Archivs dienen. Herr von Liebenau hat mir mitgeteilt, dass Sie einige schöne Dinge mit nach Hause gebracht haben, die Theotisca gehört hatten. Leider kann ich nicht sagen, dass ich in dieser Angelegenheit seit Ihrer Abreise einen Fund oder Fortschritt gemacht habe. Ich bin der schlechteste, nachlässigste Schüler des ausgezeichnetsten und erfolgreichsten Meisters! Doch ich hoffe immer noch, dass es werden kann, was noch nicht ist. Während ich Sie bitte, den armen Diaconus in der alten Zelle des Bischofs nicht ganz zu vergessen und Ihnen meine herzliche Ergebenheit versichere, habe ich die Ehre, Ihnen und Ihrer Frau Gemahlin mich und meine Familie freundlich zu empfehlen. Ihr Diac. Pupikofer. Bischofzell, den 20. Dezember 1834.', l.file = 'data/letters/lassberg-letter-1797.xml', l.has_fulltext = true, l.status = 'raw', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2509', l.repository_place = 'Frauenfeld', l.repository_institution = 'Staatsarchiv Thurgau', l.signature = '9\'45, 1.1/75.1', l.published_in = 'Johannes Meyer, Briefwechsel zwischen J. von Laszberg und Johann Adam Pupikofer. In: Alemannia 16 (1888), S. 1-32 und 97-154, S. 139', l.published_in_url = 'https://books.google.de/books?id=XWY5AAAAMAAJ';
MERGE (l:Letter {id: 'lassberg-letter-1798'}) SET l.date = '1835-01-03', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2510', l.repository_place = 'Bern', l.repository_institution = 'Burgerbibliothek';
MERGE (l:Letter {id: 'lassberg-letter-1799'}) SET l.date = '1835-02-02', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2511', l.repository_place = 'Adliswil', l.repository_institution = 'Familie Luzzi-Wirth', l.published_in = 'Arthur Brunhart, Eine Freundschaft über den Bodensee. Briefe zwischen Joseph von Laßberg und Carl Johann Greith. Ein Beitrag zur schweizerisch-deutschen Gelehrtengeschichte des 19. Jahrhunderts. In: Schriften des Vereins für Geschichte des Bodensees und seiner Umgebung 103 (1985), S. 107-63, S. 142', l.published_in_url = 'https://www.digishelf.de/piresolver?id=bsz408032952';
MERGE (l:Letter {id: 'lassberg-letter-1800'}) SET l.date = '1835-02-26', l.incipit = 'Basel, 26. Febr. 35. Hochverehrter Herr Baron, lediglich durch meine Schuld bin ich so ganz ohne Nachricht über Sie, ob und wie lange Sie schon zurück sind von Ihrem iter germanicum, wie es Ihnen währ', l.text = 'Basel, 26. Febr. 35. Hochverehrter Herr Baron, lediglich durch meine Schuld bin ich so ganz ohne Nachricht über Sie, ob und wie lange Sie schon zurück sind von Ihrem iter germanicum, wie es Ihnen während und nach derselben ergangen ist usw., dass ich nun, wo ich Ihnen so viele Bücher, die Ihnen gehören, und eins dazu, das Ihnen gehören soll, mein altdeutsches Lesebuch nämlich, zu schicken habe, mich erst zuvor erkundigen muss, ob die ganze Sendung Sie auch zu Hause treffen werde. Und von Lachmann und Hoffmann habe ich mehreres für Sie liegen, das bloß auf Ihre Antwort und diese Gelegenheit wartet. Ganz fertig ist das Lesebuch (gegen 900 Spalten) freilich noch nicht: die Vorrede ist noch im Satz, aber es schien mir endlich doch Zeit anzufragen. Erfreuen Sie mich, verehrtester Herr und Gönner, bald mit einem gütigen Bescheid; ich hoffe zu vernehmen, dass es Ihnen wohl geht und wohl gegangen ist. Mit aufrichtiger Hochachtung und Ergebenheit Wil. Wackernagel St. Johann 31.', l.file = 'data/letters/lassberg-letter-1800.xml', l.has_fulltext = true, l.status = 'reviewed', l.lang = 'de', l.publication_status = 'online', l.harris_number = '2512', l.repository_place = 'Basel', l.repository_institution = 'Staatsarchiv des Kantons Basel-Stadt', l.facsimile_url = 'https://dls.staatsarchiv.bs.ch/records/416589/4186313/preview';
MERGE (l:Letter {id: 'lassberg-letter-1801'}) SET l.date = '1835-03-01', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2513', l.repository_place = 'Bern', l.repository_institution = 'Burgerbibliothek';
MERGE (l:Letter {id: 'lassberg-letter-1802'}) SET l.date = '1835-03-04', l.incipit = 'Aschermittwoch 1835. In Erwiderung Ihrer werten Zeilen vom 26. Februar, die ich vorgestern erhielt, erzähle ich Ihnen mein verehrtester Herr Professor! dass ich erst am 11. September v. i. von der Vil', l.text = 'Aschermittwoch 1835. In Erwiderung Ihrer werten Zeilen vom 26. Februar, die ich vorgestern erhielt, erzähle ich Ihnen mein verehrtester Herr Professor! dass ich erst am 11. September v. i. von der Villa Epponis verreiste, einen Tag bei Uhland in Tübingen und einen anderen bei Schwab in Stuttgart zubrachte und dann über Speyer, Worms, Mainz, Koblenz, Bonn, Köln und Düsseldorf nach Münster in Westfalen gelangte: eine Stunde davon zu Rüschhaus fand ich diejenige, mit welcher ich seit 3 Jahren Briefe wechselte und wegen welcher ich eigentlich die Reise unternahm. Am Jahrestage der Leipziger Schlacht vermählte ich mich mit dieser Jenny Droste zu Hülshoff und trat auch denselben Tag meine Heimreise an; allein das Abschiednehmen meiner Frau bei 17 oder noch mehr Oheimen, Muhmen, Vettern und Basen verzögerte dieselbe ungemein. In Herstelle an der Weser, dessen alte Kaiserburg eine Muhme meiner Frau mit einer neuen überbaut hat, ließ ich meine Frau und ging über den Solling nach Göttingen. Ich traf die lieben Freunde Grimm nicht so an, wie ich wünschte: Wilhelm war wirklich krank und bekam, nach meiner Abreise, eine Brustentzündung, Jacob litt ein wenig an den Augen, konnte aber doch ausgehen; seine deutsche Mythologie, von welcher schon 128 Seiten der Einleitung und ebenso viel am Text gedruckt waren, schreitet rasch vorwärts; er gab mir einige Aushängebogen mit, weil er meinte ich könne ihm auch einige Beiträge liefern: er und ich brachten einen Abend bis tief in die Nacht, recht studentisch fidel bei dem wackeren Benecke, meinem Landsmanne zu; auch ein anderer Landsmann, der 84-jährige Reuß, nahm mich sehr freundlich auf. Von der Universität sah ich nichts als die Bibliothek, das heißt ich sah die Säle und Rücken der Bücher; ich ging nach wenigen Tagen traurig von der Georgia Augusta hinweg, weil ich meine Freunde unwohl zurücklassen musste; nun aber habe ich gottlob Nachricht, dass Wilhelm seine Krankheit überstanden und gänzlich auf der Besserung ist. Auf der Heimreise besuchte ich zu Bonn den Herren B. Hundeshagen; denn mich gelüstete gar zu sehr, seinen Codex des Nibelungenliedes zu sehen; es kostete mich aber viel Mühe, Überredung und eine lederne Geduld bis ich bei dem zweiten Besuch endlich dazu gelangte. Eine Papierhandschrift aus der Mitte des XV. Jahrhunderts in klein Folio, mit einigen 40 sehr mittelmäßigen Aquarellgemälden, der Text ist schon sehr verdorben und häufig interpoliert; - was er mehr hat als andere Handschriften, ist von keinem kritischen Werte, indessen ist es mir doch lieb aus Selbstansicht endlich zu wissen; wie viel oder wie wenig der Codex wert ist. H. Hundeshagen gehört unter die unglücklichen Seher, deren Augen sich alles anders darstellet als den Augen anderer gesunder Menschen; bei uns Schwaben nennt man solche Leute mit der Pelzkappe geschossen. Ich nahm meinen Weg nach Hause wieder über Stuttgart und Tübingen, wo ich wieder einen schönen Tag mit Uhlands zubrachte. Am 8. Dezember kamen wir endlich in der Zelle des heiligen Eppo an, die wir seitdem nicht verlassen haben und auch sobald nicht zu verlassen gedenken und in welcher es mir besser als jemals gefällt. Die Grüße von Grimms an Sie will ich hiermit hier interpolieren, obschon sie eigentlich dem Texte angehören: Syd mans alles reden sol, So ist zer Welt niemand wohl Wann der ein liebes Weib hat, Und sich auf ihr Treue lässt. Wenn Sie verehrtester Herr! mir nun meine Handschriften und Bücher, nach gemachtem Gebrauch, wieder senden wollen, so ist es mir ganz recht: wie sehr erfreuten Sie mich durch die Nachricht, dass Sie mir auch etwas von Lachmann und Hofmann mitzusenden haben; auf das von ersterem bin ich äußerst begierig, es kann nur etwas sehr Gutes sein, der alte Benecke tut ganz hochfahrend mit diesem Jünger, und die sonst so lobkargen Grimms lassen ihm alle Gerechtigkeit widerfahren. H. Hofmann kenne ich nicht persönlich; in Stuttgart sagte mir Schwab, dass er mit Schmeller mich den letzten Herbst besuchen wollte, als sie zusammen in der Schweiz waren, wo sie meine Abwesenheit erfuhren. Jacob Grimm zeigte mir ein altdeutsches Fragment, das Hofmann auf der Bibliothek zu Basel entdeckt und dort hat drucken lassen; ein anderes Bruchstück aus der fürstenbergischen Bibliothek zu Prag, das er dort durchreisend herausgab, las ich noch auf der Reise. Wie sehr freue ich mich auf Ihr Altdeutsches Lesebuch und die Nachricht von seiner Beendigung! Benecke und Grimm lobten diese Idee sehr und glaubten sie sei in der Ausführung in gute Hände gefallen. Jetzt bedauere ich Ihnen nicht noch mehr Inedita aus meinem Vorrat gesendet zu haben; aber ich war damals mit ganz anderen Dingen beschäftigt und mit dem Gemüte schon halb von hier abwesend. Sehr verbunden werde ich Ihnen sein, wenn Sie die Güte haben wollen, mir jetzt schon so viel davon zukommen zu lassen, als bereits gedruckt ist. Masmanns Gothica haben Sie wohl auch schon gelesen: es will mir doch vorkommen, als wenn das wenige mitgeteilte und das ganze eroberte doch noch nicht so gewaltig wichtig wäre, als der gute Gevatter meint. Nun genug für heute! Leben Sie wohl, Gott befohlen von Ihrem ergebensten JvLaßberg.', l.file = 'data/letters/lassberg-letter-1802.xml', l.has_fulltext = true, l.status = 'reviewed', l.lang = 'de', l.publication_status = 'online', l.harris_number = '875', l.journal_number = '22', l.repository_place = 'Basel', l.repository_institution = 'Staatsarchiv des Kantons Basel-Stadt', l.facsimile_url = 'https://dls.staatsarchiv.bs.ch/records/416589/4186313/preview', l.published_in = 'Wackernagel: Albert Leitzmann, Briefe aus dem Nachlaß Wilhelm Wackernagels. VI.: Briefe von Joseph von Laßberg. In: Abhandlungen der phil.-hist. Klasse der Kgl. Sächsischen Gesellschaft der Wissenschaften 34,1. Leipzig 1916, S. 92-130, S. 110-13';
