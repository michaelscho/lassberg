MERGE (l:Letter {id: 'lassberg-letter-1691'}) SET l.date = '1832-09-11', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '836', l.journal_number = '217', l.repository_place = 'St.Gallen', l.repository_institution = 'Kantonsbibliothek', l.signature = 'Vadianische Sammlung Ms 350 BA 280';
MERGE (l:Letter {id: 'lassberg-letter-1692'}) SET l.date = '1832-10-06', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2442', l.repository_place = 'Winterthur', l.repository_institution = 'Stadtbibliothek', l.signature = 'Ms BRH 513/91', l.published_in = 'Carl Ritter, Briefwechsel zwischen Joseph Freiherrn von Lassberg und Johann Caspar Zellweger. St.Gallen 1889, S. 144', l.published_in_url = 'https://books.google.de/books?id=KIHHQBvr1nkC';
MERGE (l:Letter {id: 'lassberg-letter-1693'}) SET l.date = '1832-11-01', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2443', l.repository_place = 'Bern', l.repository_institution = 'Burgerbibliothek';
MERGE (l:Letter {id: 'lassberg-letter-1694'}) SET l.date = '1832-11-09', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2444', l.repository_place = 'Marbach am Neckar', l.repository_institution = 'Schiller Nationalmuseum';
MERGE (l:Letter {id: 'lassberg-letter-1695'}) SET l.date = '1832-11-10', l.incipit = 'Mein hochverehrter Herr! Herr Dr. Kern versichert, von Ihnen keinen Brief empfangen zu haben, also an den daraus entstandenen Irrungen ohne Schuld zu sein. Er wird künftige Woche in Weinfelden sein un', l.text = 'Mein hochverehrter Herr! Herr Dr. Kern versichert, von Ihnen keinen Brief empfangen zu haben, also an den daraus entstandenen Irrungen ohne Schuld zu sein. Er wird künftige Woche in Weinfelden sein und von dort aus zu Ihnen kommen; aber da er den Tag noch nicht bestimmt weiß, kann er auch nichts genaueres darüber bestimmen. Die Kommissionen des großen Rats, der Erziehungsrat, der Kriegsrat, das Obergericht usw. nehmen den guten Mann von allen Seiten so in Anspruch, dass er beinahe nie Herr seiner Zeit ist. Höchst wahrscheinlich jedoch wird der Donnerstag Abend Ihren Rechts - Konsulenten zu Ihnen führen. Unsere Reise nach Dießenhofen ging, der stürmischen Witterung und der schlechten Pferde des neuen Hauptortes usw. hindernden Umstände ungeachtet gut von Statten; allein die Mémoires des Marschalls von Mont Luc brachte ich Ihnen nicht mit, weil Herr Benker dieselben nicht besitzt. Dagegen sende ich zu Handen des Herrn von Liebenau einige Schriften, die derselbe kennenlernen möchte. Auch die letzte Sendung des Anzeigers lege ich bei für den Fall, dass Sie den Tannhäuser noch nicht im Drucke gesehen haben. Wenn Ihr neuer Wein saust, werde ich mir das Vergnügen machen, Sie zu besuchen. In Dießenhofen hat die gute Gesellschaft mir viel Geschmack für den Sauser beigebracht, und da werde ich dann bei Ihnen eine Wiederholung meiner Fortschritte vornehmen. Bis dies geschieht, und noch lange darüber hinaus, bin ich Ihr Ergebenster Pupikofer. Bischofzell, den 10. Nov. 1832.', l.file = 'data/letters/lassberg-letter-1695.xml', l.has_fulltext = true, l.status = 'raw', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2445', l.repository_place = 'Frauenfeld', l.repository_institution = 'Staatsarchiv Thurgau', l.signature = '9\'45, 1.1/75.1', l.published_in = 'Johannes Meyer, Briefwechsel zwischen J. von Laszberg und Johann Adam Pupikofer. In: Alemannia 16 (1888), S. 1-32 und 97-154, S. 137', l.published_in_url = 'https://books.google.de/books?id=XWY5AAAAMAAJ';
MERGE (l:Letter {id: 'lassberg-letter-1696'}) SET l.date = '1832-11-13', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2446', l.repository_place = 'Aarau', l.repository_institution = 'Staatsarchiv', l.published_in = 'Eduard Vischer, Politik und Freundschaft. Der Briefwechsel des Freiherrn J. von Laßberg und K.R. Tanners in Auswahl. In: Argovia 60 (1948), S. 89-149, S. 134', l.published_in_url = 'https://www.e-periodica.ch/digbib/view?pid=arg-001%253A1948%253A60';
MERGE (l:Letter {id: 'lassberg-letter-1697'}) SET l.date = '1832-11-17', l.incipit = 'Mein hochverehrter Herr und Gönner! Wer sich entschuldigt, eh\' man klagt, der zeigt, dass er gefehlet hat." Diese alte Weisheit ist mir so früh und so nachdrücklich eingeprent worden, dass ich, indem ', l.text = 'Mein hochverehrter Herr und Gönner! Wer sich entschuldigt, eh\' man klagt, der zeigt, dass er gefehlet hat." Diese alte Weisheit ist mir so früh und so nachdrücklich eingeprent worden, dass ich, indem ich dieses Blättchen zur Hand nehme, in Besorgnis gerate, Sie könnten diese Regel auf mich anwenden und es als Beweis meiner Nachlässigkeit ansehen, dass Dr. Kern, entgegen meiner Zusicherung, nicht bei Ihnen erschienen ist. Es würde mich sehr schmerzen, wenn Sie so von mir denken würden, darum wollte ich nicht säumen, Ihnen zu berichten, dass Dr. Kern Ihnen morgen halbweise seine Entschuldigung senden wird. Er war nur am Freitag bei uns in Weinfelden. Die Siebener Kommission des Großen Rates hielt ihn stets in Frauenfeld fest. So viel er mir sagte, will er den Tag des Gerichtes, das Ihre Sache beurteilen soll, zuerst erfragen und dann, wenn dieser Tag in seine Geschäftsordnung passt, bei Ihnen Instruktion holen. In der Zwischenzeit versprach ich, den Präsidenten über den Gerichtstag zu befragen, um dann möglichst schnell Herrn Kern informieren zu können. Nachdem ein langer Gesetzesentwurf ins Reine geschrieben und dem Kleinen und Großen Rat übergeben sein wird, genieße ich eine Geschäftsferie von drei Wochen, in welcher Zeit ich wieder ein wenig in die alte Welt mich versenken zu können hoffe. Bei solcher Muße, wissen Sie wohl, bin ich nirgends lieber als bei Ihnen, und darum werde ich auf Ihre gewohnte Gastfreundschaft wieder Anspruch machen. Ihnen und Herrn von Liebenau mich und die Meinigen zu freundschaftlicher Gewogenheit empfehlend, bin ich Ihr Ergebenster Diak. Pupikofer. Bischofzell, 17. Nov. 32.', l.file = 'data/letters/lassberg-letter-1697.xml', l.has_fulltext = true, l.status = 'raw', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2447', l.repository_place = 'Frauenfeld', l.repository_institution = 'Staatsarchiv Thurgau', l.signature = '9\'45, 1.1/75.1', l.published_in = 'Johannes Meyer, Briefwechsel zwischen J. von Laszberg und Johann Adam Pupikofer. In: Alemannia 16 (1888), S. 1-32 und 97-154, S. 138', l.published_in_url = 'https://books.google.de/books?id=XWY5AAAAMAAJ';
