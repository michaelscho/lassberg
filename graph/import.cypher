MERGE (l:Letter {id: 'lassberg-letter-1379'}) SET l.date = '1829-12-07', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '685', l.journal_number = '255', l.repository_place = 'Trogen', l.repository_institution = 'Kantonsbibliothek Appenzell A.Rh.', l.published_in = 'Carl Ritter, Briefwechsel zwischen Joseph Freiherrn von Lassberg und Johann Caspar Zellweger. St.Gallen 1889, S. 105-09', l.published_in_url = 'https://books.google.de/books?id=KIHHQBvr1nkC';
