MERGE (l:Letter {id: 'lassberg-letter-0965'}) SET l.date = '1825-02-21', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2042', l.repository_place = 'Krakau', l.repository_institution = 'Jagiellonische Bibliothek', l.published_in = 'Franz Pfeiffer, Zur Geschichte der deutschen Philologie. Briefe an Joseph Freiherrn von Laßberg. Postum hg. von Joseph Maria Wagner. In: Germania 13 (1868), S. 118-27, 244-49, 365-84 und 487-508, S. 247', l.published_in_url = 'https://upload.wikimedia.org/wikipedia/commons/a/a8/Germania_13_1868.pdf';
MERGE (l:Letter {id: 'lassberg-letter-0966'}) SET l.date = '1825-02-24', l.incipit = 'Hochwohlgeborener Herr! Mit herzlichem Dank sende ich Ihnen hiermit Neugart\'sches episcopalis Const. und Zapfii Monum. zurück; ich fand sehr viel Belehrung, besonders in dem erstgenannten Werk, und mö', l.text = 'Hochwohlgeborener Herr! Mit herzlichem Dank sende ich Ihnen hiermit Neugart\'sches episcopalis Const. und Zapfii Monum. zurück; ich fand sehr viel Belehrung, besonders in dem erstgenannten Werk, und möchte mit so vielen Freunden der alten Geschichte wünschen, dass auch der zweite Teil gedruckt würde. Von Zapfii Monum. bitte ich Sie um den zweiten Teil, sowie auch um das Chronicon Peterhusanum. Von altertümlichen Neuigkeiten gelangt, wenn sie so entfernt sind, wenig in des Bischofs Celle. Doch hatte Herr Pfarrer Kirchhofer die Gefälligkeit, mir ein Heft seiner Auszüge mitzuteilen, worin manches wertvolle aus dem 14. und 15. Jahrhundert vorkommt. Die Reimchronik vom Appenzeller Krieg ist Ihnen wahrscheinlich durch den Herausgeber bekannt geworden. Indem ich Sie, hochwohlgeborener, verehrter Herr! meiner ausgezeichneten Hochachtung versichere und Sie um Ihre weitere Gewogenheit bitte, habe ich die Ehre zu sein Hochdero ergebenster Diac. Pupikofer Bischofzell, den 24. Februar 1825.', l.file = 'data/letters/lassberg-letter-0966.xml', l.has_fulltext = true, l.status = 'reviewed', l.lang = 'de', l.publication_status = 'in_oxygen_done', l.harris_number = '2043', l.repository_place = 'Frauenfeld', l.repository_institution = 'Staatsarchiv Thurgau', l.signature = '9\'45, 1.1/75.1', l.published_in = 'Johannes Meyer, Briefwechsel zwischen J. von Laszberg und Johann Adam Pupikofer. In: Alemannia 15 (1887), S. 231-88, S. 285', l.published_in_url = 'https://books.google.de/books?id=dXkKAAAAIAAJ';
MERGE (l:Letter {id: 'lassberg-letter-0967'}) SET l.date = '1825-02-28', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2044', l.repository_place = 'Weimar', l.repository_institution = 'Goethe- und Schillerarchiv';
