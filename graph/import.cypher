MERGE (l:Letter {id: 'lassberg-letter-1793'}) SET l.date = '1834-10-18', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '873', l.repository_place = 'Erpernburg', l.repository_institution = 'Archiv der Freiherren von und zu Brenken', l.published_in = 'Alfred Cohausz, Der Schwager der Annette von Droste. 20 unbekannte Briefe des Reichsfreiherrn Joseph von Laszberg aus den Jahren 1814 (richtig: 1817)-1849. In: WZ 95 (1939), S. 45-87, S. 63', l.published_in_url = 'https://www.lwl.org/westfaelische-geschichte/txt/wz-9716.pdf';
