MERGE (l:Letter {id: 'lassberg-letter-0969'}) SET l.date = '1825-03-11', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '497', l.journal_number = '68', l.repository_place = 'Trogen', l.repository_institution = 'Kantonsbibliothek Appenzell A.Rh.', l.signature = 'Fa Zellweger 40/C 01, Bd. 4, S. 1244-1247', l.published_in = 'Carl Ritter, Briefwechsel zwischen Joseph Freiherrn von Lassberg und Johann Caspar Zellweger. St.Gallen 1889, S. 65', l.published_in_url = 'https://books.google.de/books?id=KIHHQBvr1nkC';
MERGE (l:Letter {id: 'lassberg-letter-0970'}) SET l.date = '1825-03-11', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '498', l.journal_number = '69', l.repository_place = 'Aarau', l.repository_institution = 'Staatsarchiv', l.published_in = 'Karl Siegfried Bader (Hg.), Joseph von Lassberg. Mittler und Sammler. Aufsätze zu seinem 100. Todestag. Stuttgart 1955, S. 14';
MERGE (l:Letter {id: 'lassberg-letter-0971'}) SET l.date = '1825-03-11', l.incipit = 'Eppishausen, den 11. März 1825 Verehrter Herr! Mit der angelegentlichsten Bitte: es mir zugute zu halten, dass ich Ihr Buch so lange behielt und mit dem besten Dank für dessen mir gestatteten Gebrauch', l.text = 'Eppishausen, den 11. März 1825 Verehrter Herr! Mit der angelegentlichsten Bitte: es mir zugute zu halten, dass ich Ihr Buch so lange behielt und mit dem besten Dank für dessen mir gestatteten Gebrauch, sende ich Ihnen den IV. Band von Raumers Geschichte der Hohenstaufen hier zurück: die anhaltende Krankheit meines Freundes von Ittner, welche vorgestern mit dessen Hinscheiden endete, erlaubte mir nicht, an etwas anderes zu denken. Seit gestern Abend bin ich mit seiner Witwe und Tochter hier angekommen; sie wollen die ersten Tage der Trauer in dieser Einsamkeit zubringen. Gerne würde ich Ihrem Wunsch entsprechen und Ihnen den II. Band von Zapfs Monument: anecdot: übermachen; allein, ich habe ihn nicht und zweifle, ob ein solcher herausgekommen ist; doch habe ich in Augsburg deshalb Erkundigungen anstellen lassen. Die Handschrift Trutpert Neugarts zum II. Band des Episcopatus Constantiensis liegt schon im zweiten Jahr bei dem H. Graven Mülinen zu Bern, welchem der Verfasser sie zur Herausgabe überlassen hat; aber bei der geschwächten Gesundheit dieses würdigen Mannes ist wohl keine Hoffnung zur Bewerkstelligung dieser Herausgabe. Das Gedicht, welches eigentlich nur bis zum Anfange des Appenzeller Krieges reicht, hat weder geschichtlichen noch poetischen Wert und würde wohl ebenso gut ungedruckt geblieben sein, was ich mir die Freiheit nahm, dem H. von Arx schon vor mehr als drei Jahren zu äußern. Auch aus dem I. Bande von Anselms Bernerchronik habe ich wenig Trost geschöpft, und ziehe Justinger und Tschachtlan weit vor. Eine nicht uninteressante Geschichte eines böhmischen Freiherren von Rozmital aus dem 15. Jahrhundert sende ich Ihnen von Konstanz aus. Indessen leben Sie wohl und gedenken Sie zuweilen mit Liebe Ihres herzlich betrübten gehorsamen Dieners. Joseph von Laßberg.', l.file = 'data/letters/lassberg-letter-0971.xml', l.has_fulltext = true, l.status = 'reviewed', l.lang = 'de', l.publication_status = 'online', l.harris_number = '499', l.journal_number = '71', l.repository_place = 'Winterthur', l.repository_institution = 'Stadtbibliothek', l.signature = 'Ms BRH 46/5', l.published_in = 'Johannes Meyer, Briefwechsel zwischen J. von Laszberg und Johann Adam Pupikofer. In: Alemannia 15 (1887), S. 231-88, S. 231', l.published_in_url = 'https://books.google.de/books?id=dXkKAAAAIAAJ';
