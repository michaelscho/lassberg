MERGE (l:Letter {id: 'lassberg-letter-1051'}) SET l.date = '1825-12-03', l.incipit = 'Hochwohlgeborener, verehrtester Herr! Mit herzlichem Dank sende ich den ersten Band von Kopps Bildern und Schriften der Vorzeit an Sie zurück. Ich habe die Schrift mit Vergnügen gelesen und werde Sie ', l.text = 'Hochwohlgeborener, verehrtester Herr! Mit herzlichem Dank sende ich den ersten Band von Kopps Bildern und Schriften der Vorzeit an Sie zurück. Ich habe die Schrift mit Vergnügen gelesen und werde Sie bei Gelegenheit auch um Mitteilung der Fortsetzung bitten. Ebenso dankbar bin ich Ihnen für die Auszüge aus Öhms Chronik. Schon Tschudi erzählt vom Tode Graf Wezels von Bürglen ad. a. 1074 und auch Neugart episc. I. p. 412 bezieht sich darauf, ohne nähere Aufklärung zu geben, sodass allerdings die Umstände, die Öhm angibt, wichtig sind. Aber der Continuator Hermanni berichtet ad. a. 1061, dass Burchardus und Wezilo Zollerani im Kampf gegen den Zähringer umgekommen sind. Wäre hier nicht eine Verwechslung möglich? Wie ich den Codex probat. von Herrgott durchging, fiel mir in Charta 157 der Ort Chenzinga bei Riegel im Badischen auf. Ist vielleicht dies der Stammort derer von Kenzingen, die dem Inhalt der Charta zufolge Vasallen der Habsburger gewesen sein müssten? Laut Ch. 510 scheint der Vogt Jacobus von Vrowenfeld mit dem Edlen von Wiesendangen verwandt gewesen zu sein. Die Edlen von Wiesendangen aber waren Dienstleute zu Kyburg. Das Wappen der Hofmeister zu Frauenfeld und der Edlen zu Wiesendangen ist bei Stumpf fast übereinstimmend. Mit Myllers Sammlung altdeutscher Gedichte bin ich leider noch nicht zu Ende gekommen. Sollten Sie dieselben benötigen, so bitte ich um Ihren Befehl; wenn nicht, erlauben Sie mir, sie noch einige Wochen zu behalten. Am Anfang dieser Woche fand ich Sie noch nicht auf Ihrem Musensitz. Nächste Woche, bis zum Donnerstag, habe ich Geschäfte in Frauenfeld und werde Ihnen die gewünschten Urkunden besorgen. Auf diese Weise muss ich noch lange auf Ihren belehrenden und angenehmen Umgang verzichten. Genehmigen Sie, Hochwohlgeborener, verehrtester Herr, die Versicherung dankbarer Hochachtung und Ergebenheit von Ihrem Diakon Irem Pupikofer. Bischofzell, den 3. Dezember 1825.', l.file = 'data/letters/lassberg-letter-1051.xml', l.has_fulltext = true, l.status = 'reviewed', l.lang = 'de', l.publication_status = 'in_oxygen_done', l.harris_number = '2100', l.repository_place = 'Frauenfeld', l.repository_institution = 'Staatsarchiv Thurgau', l.signature = '9\'45, 1.1/75.1', l.published_in = 'Johannes Meyer, Briefwechsel zwischen J. von Laszberg und Johann Adam Pupikofer. In: Alemannia 16 (1888), S. 1-32 und 97-154, S. 1', l.published_in_url = 'https://books.google.de/books?id=XWY5AAAAMAAJ';
