MERGE (l:Letter {id: 'lassberg-letter-1855'}) SET l.date = '1836-07-24', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '907', l.journal_number = '128', l.repository_place = 'Aarau', l.repository_institution = 'Staatsarchiv', l.published_in = 'Eduard Vischer, Politik und Freundschaft. Der Briefwechsel des Freiherrn J. von Laßberg und K.R. Tanners in Auswahl. In: Argovia 60 (1948), S. 89-149, S. 146/R', l.published_in_url = 'https://www.e-periodica.ch/digbib/view?pid=arg-001%253A1948%253A60';
