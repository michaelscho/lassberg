MERGE (l:Letter {id: 'lassberg-letter-1241'}) SET l.date = '1828-08-16', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '608', l.journal_number = '142', l.repository_place = 'Tübingen', l.repository_institution = 'Universitätsbibliothek';
MERGE (l:Letter {id: 'lassberg-letter-1242'}) SET l.date = '1828-08-23', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '609', l.journal_number = '159', l.repository_place = 'Donaueschingen', l.repository_institution = 'Fürstlich Fürstenbergisches Archiv';
MERGE (l:Letter {id: 'lassberg-letter-1243'}) SET l.date = '1828-08-27', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '610', l.journal_number = '168', l.repository_place = 'Donaueschingen', l.repository_institution = 'Fürstlich Fürstenbergisches Archiv';
MERGE (l:Letter {id: 'lassberg-letter-1244'}) SET l.date = '1828-09-15', l.incipit = 'Verehrtester Herr und Gönner! Der Buchbinder Gonzenbach sandte mir Ihr Exemplar von der Thurgauer Geschichte, um es Ihnen zu übergeben, was ich hiermit tue. Ich lege die Fortsetzung meines Codex Proof', l.text = 'Verehrtester Herr und Gönner! Der Buchbinder Gonzenbach sandte mir Ihr Exemplar von der Thurgauer Geschichte, um es Ihnen zu übergeben, was ich hiermit tue. Ich lege die Fortsetzung meines Codex Proofus bei, nebst der Zürcher historischen Zeitschrift. Sie haben die letzte schöne Woche nicht für einen Spaziergang nach Bischofzell genutzt; dafür regnet es nun wieder und sogar der Barometer vermag nichts dagegen. Wenn Sie Ihren versprochenen Besuch nicht noch diese Woche abstatten, sondern weiter bis auf die kommende Woche verschieben, so seien Sie gewarnt, wenn Sie ungepflegt daher kommen, denn meine Frau gedenkt dann das Herbstwasser- und Reinigungsfest zu feiern. Wenn Sie uns in Erinnerung der Frau Doktor und der freundlichen Adelheid auffrischen wollen, so würden Sie uns sehr erfreuen. Zwischen Ihnen und mir lasse ich es gerne, wie Sie sagen, beim Alten. Ihr Pupikofer. den 15. September 1828.', l.file = 'data/letters/lassberg-letter-1244.xml', l.has_fulltext = true, l.status = 'raw', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2213', l.repository_place = 'Frauenfeld', l.repository_institution = 'Staatsarchiv Thurgau', l.signature = '9\'45, 1.1/75.1', l.published_in = 'Johannes Meyer, Briefwechsel zwischen J. von Laszberg und Johann Adam Pupikofer. In: Alemannia 16 (1888), S. 1-32 und 97-154, S. 24', l.published_in_url = 'https://books.google.de/books?id=XWY5AAAAMAAJ';
