MERGE (l:Letter {id: 'lassberg-letter-2058'}) SET l.date = '1838-08-13', l.incipit = 'Seiner Wohlwürden Herren Camerer und Diacon Pupikofer, zu Bischofszelle samt einer Kiste Bücher enthaltend (frei.) Eppishausen, am 13. August 1838. Hier mein hochgeschätzter Freund! kommen endlich die', l.text = 'Seiner Wohlwürden Herren Camerer und Diacon Pupikofer, zu Bischofszelle samt einer Kiste Bücher enthaltend (frei.) Eppishausen, am 13. August 1838. Hier mein hochgeschätzter Freund! kommen endlich die Bücher; welche ich gerne früher geschickt hätte, wenn nicht die beinahe täglichen Fahrten an das Seeufer die Pferde ununterbrochen in Beschlag nähmen: heute haben sie Rasttag, also schadet ihnen die kurze Promenade in der Abendkühle nichts. Ich komme mir vor, wie eine Garnison, welche aus einer kapitulierten Festung abzieht, je näher der letzte Tag rückt, je mehr sträubt man sich; allein, es muss nun einmal sein und da hilft, wie Hanswurst sagt, kein Zittern für den Frost! Einen schönen, vielleicht den schönsten meiner Pläne für die Zukunft, hat vor kurzem der Tod zerstört! Mein guter Fritz wollte noch 4 Jahre dienen und dann an einem der Ufer des Bodensees ganz der Wissenschaft leben. Unsere vereinten Büchersammlungen würden uns vielleicht zu gleichen Arbeiten vereinigt haben. Cur, quos jungit amor, fatum disjungis iniquum? Nun ist mir die alte Meersburg auch viel weniger wert; denn der mit mir gearbeitet, der mich fortgesetzt hätte, für den ich gesammelt und gearbeitet hatte, ist nicht mehr! Möge denn Ihnen, mein Freund! mit Ihrem Ernst ein fröhlicheres Schicksal bewahrt sein. Leben Sie wohl und grüßen Sie die Ihren, von Ihrem nun an leib und Seele hinkenden Jv. Laßberg. Sehen Sie Scherbs und Imhoff, so bitte ich sie von uns allen zu grüßen.', l.file = 'data/letters/lassberg-letter-2058.xml', l.has_fulltext = true, l.status = 'raw', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '1011', l.journal_number = '218', l.repository_place = 'Winterthur', l.repository_institution = 'Stadtbibliothek', l.signature = 'Ms BRH 46/5', l.published_in = 'Johannes Meyer, Briefwechsel zwischen J. von Laszberg und Johann Adam Pupikofer. In: Alemannia 15 (1887), S. 231-88, S. 278', l.published_in_url = 'https://books.google.de/books?id=dXkKAAAAIAAJ';
