MERGE (l:Letter {id: 'lassberg-letter-1077'}) SET l.date = '1826-03-11', l.incipit = 'Hochwohlgeborner, verehrtester Herr! Mit herzlichem Dank sende ich Ihnen hier Müllers Sammlung von Minneliedern zurück. Ich muss nochmals um Verzeihung bitten, dieselben so lange behalten zu haben. De', l.text = 'Hochwohlgeborner, verehrtester Herr! Mit herzlichem Dank sende ich Ihnen hier Müllers Sammlung von Minneliedern zurück. Ich muss nochmals um Verzeihung bitten, dieselben so lange behalten zu haben. Dem Gallus Öhem habe ich gestern zwei Kopien von Arboner Urkunden beigelegt; dieselben sollten genau sein; selbst einige Nachlässigkeiten und Auslassungen des Textes wollte ich nicht verbessern. Von Marquart von Chemenat werde ich Ihnen nächstens gleichfalls zustellen. Meinen Besuch bei Ihnen werde ich, wenn Sie es gütigst erlauben, künftigen Mittwoch oder Donnerstag wiederholen. Doch nein, am Mittwoch kann es nicht sein! Also am Donnerstag. Unterdessen habe ich die Ehre zu verharren Dero ergebenster Diac. Pupikofer. Bischofzell, den 11. März 1826.', l.file = 'data/letters/lassberg-letter-1077.xml', l.has_fulltext = true, l.status = 'reviewed', l.lang = 'de', l.publication_status = 'in_oxygen_done', l.harris_number = '2116', l.repository_place = 'Frauenfeld', l.repository_institution = 'Staatsarchiv Thurgau', l.signature = '9\'45, 1.1/75.1', l.published_in = 'Johannes Meyer, Briefwechsel zwischen J. von Laszberg und Johann Adam Pupikofer. In: Alemannia 16 (1888), S. 1-32 und 97-154, S. 1', l.published_in_url = 'https://books.google.de/books?id=XWY5AAAAMAAJ';
MERGE (l:Letter {id: 'lassberg-letter-1078'}) SET l.date = '1826-03-16', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2117', l.repository_place = 'Marbach am Neckar', l.repository_institution = 'Schiller Nationalmuseum';
