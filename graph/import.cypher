MERGE (l:Letter {id: 'lassberg-letter-1272'}) SET l.date = '1829-01-09', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '624', l.journal_number = '3', l.repository_place = 'Zürich', l.repository_institution = 'Zentralbibliothek', l.signature = 'Handschriftenabteilung, Ms M 32.35';
MERGE (l:Letter {id: 'lassberg-letter-1273'}) SET l.date = '1829-01-10', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2229', l.repository_place = 'Krakau', l.repository_institution = 'Jagiellonische Bibliothek', l.published_in = 'Franz Pfeiffer, Zur Geschichte der deutschen Philologie. Briefe an Joseph Freiherrn von Laßberg. Postum hg. von Joseph Maria Wagner. In: Germania 13 (1868), S. 118-27, 244-49, 365-84 und 487-508, S. 365', l.published_in_url = 'https://upload.wikimedia.org/wikipedia/commons/a/a8/Germania_13_1868.pdf';
MERGE (l:Letter {id: 'lassberg-letter-1274'}) SET l.date = '1829-01-17', l.incipit = 'Hochwohlgeborener Herr und Gönner! Da ich einen Pack Bücher von Ihnen erwartete und dieser nicht angekommen ist, so bin ich etwas unruhig geworden; nicht etwa deswegen, weil ich der Bücher sehr bedürf', l.text = 'Hochwohlgeborener Herr und Gönner! Da ich einen Pack Bücher von Ihnen erwartete und dieser nicht angekommen ist, so bin ich etwas unruhig geworden; nicht etwa deswegen, weil ich der Bücher sehr bedürfte, sondern weil ich befürchte, Sie könnten von einem Rückfall betroffen und wieder krank geworden sein. Doch vielleicht sind Sie nach Heiligenberg verreist, durch Gäste gehindert oder über eine neue Entdeckung im alten Bardenhain so versessen, dass Sie den armen Diakon an der Sitter ganz vergessen haben. Dass ich weder so glücklich in Entdeckungen, noch so vergesslich bin, sollen Ihnen mitkommende Schriften beweisen. Das alte Zürich hat, wie ich hoffe, auch für Sie manches bemerkenswerte; die Helvetia und das St. Gallische Neujahrsblatt sind Fortsetzungen. Für den Gebrauch der Müllerschen Altertümer bin ich Ihnen sehr dankbar; sie dienten mir teilweise als Erläuterung zum alten Zürich. Sollte das Appenzellische Landbuch nicht auch Beiträge für Herrn Grimm enthalten? Mit Grimms Altertümern bin ich bald fertig; dass so viele mir unverständliche nordische Stellen angeführt und nicht übersetzt sind, verdrießt mich nicht selten. Leben Sie wohl und gedenken Sie zuweilen Ihres Pupikofer. Bischofzell, den 17. Januar 1829.', l.file = 'data/letters/lassberg-letter-1274.xml', l.has_fulltext = true, l.status = 'raw', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '2230', l.repository_place = 'Frauenfeld', l.repository_institution = 'Staatsarchiv Thurgau', l.signature = '9\'45, 1.1/75.1', l.published_in = 'Johannes Meyer, Briefwechsel zwischen J. von Laszberg und Johann Adam Pupikofer. In: Alemannia 16 (1888), S. 1-32 und 97-154, S. 29', l.published_in_url = 'https://books.google.de/books?id=XWY5AAAAMAAJ';
MERGE (l:Letter {id: 'lassberg-letter-1275'}) SET l.date = '1829-01-20', l.has_fulltext = false, l.status = 'register-only', l.lang = 'de', l.publication_status = 'in_register', l.harris_number = '625', l.journal_number = '9', l.repository_place = 'Berlin', l.repository_institution = 'Staatsbibliothek Preussischer Kulturbesitz', l.published_in = 'Albert Leitzmann, Briefe des Freiherrn Joseph von Laßberg an Jakob Grimm. In: Sitzungsberichte der Preußischen Akademie der Wissenschaften. Berlin 1931, S. 1026-1105, S. 1050-53';
